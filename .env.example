# Dovtek Backend Configuration
# Copy this file to .env and fill in your values

# Anthropic API Key (required for scan functionality)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database URL (defaults to SQLite for local dev)
# For production, use: postgresql://user:password@host:port/dbname
DATABASE_URL=sqlite:///./dovtek.db

# JWT Secret Key (change in production!)
JWT_SECRET_KEY=change-this-in-production

# Server Port
PORT=8000
